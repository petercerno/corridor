{
    "name": "corridor",
    "private": true,
    "version": "0.0.0",
    "type": "module",
    "engines": {
        "node": ">=20.0.0"
    },
    "scripts": {
        "dev": "vite client",
        "dev:all": "concurrently \"npm run server:dev\" \"npm run dev\"",
        "server:dev": "tsx server/src/index.ts",
        "build": "tsc -p client/tsconfig.json && vite build client && tsc -p server/tsconfig.json",
        "preview": "vite preview client",
        "start": "node server/dist/server/src/index.js"
    },
    "devDependencies": {
        "@types/express": "^5.0.6",
        "@types/node": "^25.5.0",
        "concurrently": "^9.2.1",
        "tsx": "^4.21.0",
        "typescript": "~5.9.3",
        "vite": "^8.0.0"
    },
    "dependencies": {
        "express": "^5.2.1",
        "phaser": "^3.90.0",
        "rate-limiter-flexible": "^10.0.1",
        "socket.io": "^4.8.3",
        "socket.io-client": "^4.8.3"
    }
}
